# ════════════════════════════════════════════════════════════════
# .env.example — Modernizer Orchestrator local dev config
# ----------------------------------------------------------------
# SETUP:
#   1. cp .env.example .env
#   2. Fill in real values in .env  (NEVER commit .env)
#   3. Ensure your .pem lives OUTSIDE the repo (see GITHUB_APP_PRIVATE_KEY_PATH)
#
# ⚠️  SECURITY — PRODUCTION RULES:
#   • ALL passwords must be >= 32 chars of cryptographically-random data.
#     Generate with:  openssl rand -base64 32
#   • Every value marked CHANGE_ME_ or REQUIRED_ MUST be replaced.
#     The app fails fast at startup if these placeholders are detected.
# ════════════════════════════════════════════════════════════════


# ════════════════════════════════════════════════════════════════
# CORE DATABASE (POSTGRES)
# ════════════════════════════════════════════════════════════════
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=modernizer
# ⚠️ DEV ONLY. Production: openssl rand -base64 32  (>= 32 chars)
POSTGRES_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_32
POSTGRES_DB=modernizer

# ════════════════════════════════════════════════════════════════
# REDIS (WARM-TIER STORAGE)
# ----------------------------------------------------------------
# Production Redis MUST set `requirepass`. This value must match it.
# For tenant isolation, use per-tenant key prefixes + Redis ACLs.
# ════════════════════════════════════════════════════════════════
REDIS_HOST=localhost
REDIS_PORT=6379
# Leave BLANK for local dev (no auth). Production: REQUIRED, >= 32 chars.
REDIS_PASSWORD=CHANGE_ME

# ════════════════════════════════════════════════════════════════
# RABBITMQ (EVENT BROKER)
# ----------------------------------------------------------------
# guest/guest ONLY works on localhost and is REJECTED on remote
# connections. For any non-localhost deployment you MUST change these
# and disable the guest user.
# ════════════════════════════════════════════════════════════════
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=CHANGE_ME_rabbitmq_user
RABBITMQ_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_32


# ════════════════════════════════════════════════════════════════
# GITHUB APP INTEGRATION CREDENTIALS (ALREADY REGISTERED)
# ════════════════════════════════════════════════════════════════
# From GitHub Developer Console → your App → "App ID"
GITHUB_APP_ID=REQUIRED_SET_YOUR_GITHUB_APP_ID
GITHUB_APP_INSTALLATION_ID=REQUIRED_SET_YOUR_INSTALLATION_ID

# ABSOLUTE path to your .pem — keep OUTSIDE the git repo
# (e.g., ~/.secrets/modernizer/modernizer-sandbox.pem)
GITHUB_APP_PRIVATE_KEY_PATH=REQUIRED_SET_ABSOLUTE_PATH_TO_YOUR_PEM


# ════════════════════════════════════════════════════════════════
# LOCAL PORTABLE AI INTEGRATION (OLLAMA - FREE & OFFLINE)
# ════════════════════════════════════════════════════════════════
SPRING_AI_OLLAMA_BASE_URL=http://localhost:11434
SPRING_AI_OLLAMA_CHAT_OPTIONS_MODEL=deepseek-r1:8b


# ════════════════════════════════════════════════════════════════
# OBJECT STORAGE (S3 / MinIO — COLD TIER)
# ════════════════════════════════════════════════════════════════
STORAGE_S3_ENDPOINT=http://localhost:9000
STORAGE_S3_BUCKET=legacy-artifacts
STORAGE_S3_ACCESS_KEY=CHANGE_ME_minio_access_key
STORAGE_S3_SECRET_KEY=CHANGE_ME_minio_secret_key


# ════════════════════════════════════════════════════════════════
# GCP CLOUD STORAGE (OPTIONAL — production cold tier)
# ----------------------------------------------------------------
# Service account needs: storage.objects.create/get/delete
# scoped with bucket-level IAM conditions for tenant-isolated storage.
# ════════════════════════════════════════════════════════════════
# GCP_PROJECT_ID=your-gcp-project-id
# GCP_BUCKET_NAME=your-tenant-isolated-bucket
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
