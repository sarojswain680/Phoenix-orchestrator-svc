# ════════════════════════════════════════════════════════════════
# .env.example — Modernizer Orchestrator local dev config
# ----------------------------------------------------------------
# SETUP:
#   1. cp .env.example .env
#   2. Fill in real values in .env  (NEVER commit .env)
#   3. Ensure your .pem lives OUTSIDE the repo (see GITHUB_APP_PRIVATE_KEY_PATH)
# ════════════════════════════════════════════════════════════════


# ════════════════════════════════════════════════════════════════
# CORE DATABASE & MESSAGING CONFIGURATION (DOCKER)
# ════════════════════════════════════════════════════════════════
POSTGRES_USER=modernizer
POSTGRES_PASSWORD=supersecurepassword123
POSTGRES_DB=modernizer_dev

# --- Added: connection coordinates the Spring app needs ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Added: Redis (warm-tier storage) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Added: RabbitMQ (you use spring-boot-starter-amqp) ---
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest


# ════════════════════════════════════════════════════════════════
# GITHUB APP INTEGRATION CREDENTIALS (ALREADY REGISTERED)
# ════════════════════════════════════════════════════════════════
# Insert your registered GitHub App ID here
GITHUB_APP_ID=your-github-app-id-here

# Point this to the local ABSOLUTE path of your downloaded .pem file
# (Keep it OUTSIDE the git repo — e.g., ~/.secrets/modernizer/)
GITHUB_APP_PRIVATE_KEY_PATH=/absolute/path/to/modernizer-sandbox.pem

# --- Added: needed to mint installation tokens for API calls ---
GITHUB_APP_INSTALLATION_ID=your-installation-id-here


# ════════════════════════════════════════════════════════════════
# LOCAL PORTABLE AI INTEGRATION (OLLAMA - FREE & OFFLINE)
# ════════════════════════════════════════════════════════════════
# Your local Ollama server address
SPRING_AI_OLLAMA_BASE_URL=http://localhost:11434

# The target local model you downloaded
SPRING_AI_OLLAMA_CHAT_OPTIONS_MODEL=deepseek-r1:8b